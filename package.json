{
  "name": "opentool",
  "version": "0.19.0",
  "description": "OpenTool framework for building serverless MCP tools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opentool": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run typecheck && tsup",
    "dev": "tsx src/cli/dev.ts",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run typecheck && npm run build && tsx scripts/sync-template.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "npm run build && npm run changeset:publish",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src"
  },
  "files": [
    "dist/**/*",
    "templates/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opentool",
    "mcp",
    "tools",
    "serverless",
    "lambda"
  ],
  "author": "OpenTool",
  "homepage": "https://opentool.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openpond/opentool.git"
  },
  "bugs": {
    "url": "https://github.com/openpond/opentool/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@alcyone-labs/zod-to-json-schema": "^4.0.10",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@msgpack/msgpack": "^3.1.1",
    "@noble/hashes": "^1.4.0",
    "@turnkey/sdk-server": "5.1.0",
    "@turnkey/viem": "0.14.25",
    "commander": "^11.0.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.25.12",
    "viem": "^2.31.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.0.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./x402": {
      "import": "./dist/x402/index.js",
      "types": "./dist/x402/index.d.ts"
    },
    "./viem": {
      "import": "./dist/viem/index.js",
      "types": "./dist/viem/index.d.ts"
    },
    "./wallet": {
      "import": "./dist/wallet/index.js",
      "types": "./dist/wallet/index.d.ts"
    },
    "./wallet/browser": {
      "import": "./dist/wallet/browser.js",
      "types": "./dist/wallet/browser.d.ts"
    },
    "./adapters/hyperliquid": {
      "import": "./dist/adapters/hyperliquid/index.js",
      "types": "./dist/adapters/hyperliquid/index.d.ts"
    },
    "./adapters/hyperliquid/browser": {
      "import": "./dist/adapters/hyperliquid/browser.js",
      "types": "./dist/adapters/hyperliquid/browser.d.ts"
    },
    "./adapters/polymarket": {
      "import": "./dist/adapters/polymarket/index.js",
      "types": "./dist/adapters/polymarket/index.d.ts"
    },
    "./adapters/news": {
      "import": "./dist/adapters/news/index.js",
      "types": "./dist/adapters/news/index.d.ts"
    },
    "./store": {
      "import": "./dist/store/index.js",
      "types": "./dist/store/index.d.ts"
    },
    "./backtest": {
      "import": "./dist/backtest/index.js",
      "types": "./dist/backtest/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    },
    "./ai": {
      "import": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts"
    }
  }
}
